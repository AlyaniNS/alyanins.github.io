            <rect x="12.5" y="2" width="9.5" height="9.5" rx="1" fill="#7FBA00"/>
            <rect x="2" y="12.5" width="9.5" height="9.5" rx="1" fill="#00A4EF"/>
            <rect x="12.5" y="12.5" width="9.5" height="9.5" rx="1" fill="#FFB900"/>
