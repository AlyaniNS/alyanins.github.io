      <span class="folder-count">{dataProjects.length} item{dataProjects.length !== 1 ? 's' : ''}</span>
    </button>
  </div>

  <!-- ── CENTER TITLE ─────────────────────────────── -->
  <div class="slot-center">
    <div class="note-center">
      <span class="center-name">Alyani<br/>Septalia</span>
      <span class="center-sub">Portfolio</span>
    </div>
  </div>

  <!-- ── STACK sticky (SW) ───────────────────────── -->
