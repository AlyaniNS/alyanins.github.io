          <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="note-body" id="note-body-certs">
      <div class="cert-list">
        <!-- Huawei HCIA Datacom -->
