    <button class="folder-btn" data-open-folder="folder-web" aria-label="Open Website Portfolio">
      <FolderWeb class="folder-svg" />
      <span class="folder-name-label">Website<br/>Portfolio</span>
      <span class="folder-count">{webProjects.length} item{webProjects.length !== 1 ? 's' : ''}</span>
