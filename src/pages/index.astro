<!-- ═══════════════ SCRIPTS ═══════════════ -->
<script>
  function openDlg(el: HTMLDialogElement) {
    if (typeof el.showModal === 'function') el.showModal();
    else { el.setAttribute('open', ''); (el as any).style.display = 'flex'; }
  }
  function closeDlg(el: HTMLDialogElement) {
    if (typeof el.close === 'function') el.close();
    else { el.removeAttribute('open'); (el as any).style.display = 'none'; }
  }

  // Open folder
  document.querySelectorAll<HTMLButtonElement>('[data-open-folder]').forEach(btn => {
    btn.addEventListener('click', () => {
      const dlg = document.getElementById(btn.dataset.openFolder!) as HTMLDialogElement | null;
      if (dlg) openDlg(dlg);
    });
  });

  // Close finder: red dot or backdrop
  document.querySelectorAll<HTMLDialogElement>('.finder-window').forEach(d => {
    d.querySelector('[data-close-folder]')?.addEventListener('click', () => closeDlg(d));
    d.addEventListener('click', e => {
      const r = d.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) closeDlg(d);
    });
  });

  // Note expand overlay
  const ovBackdrop = document.getElementById('note-ov-backdrop')!;
  const ovPanel    = document.getElementById('note-ov')!;
  const ovLabel    = document.getElementById('note-ov-label')!;
  const ovTitle    = document.getElementById('note-ov-title')!;
  const ovBody     = document.getElementById('note-ov-body')!;

  function openOverlay(note: HTMLElement) {
    const label = note.querySelector<HTMLElement>('.note-label')?.textContent ?? '';
    const title = note.querySelector<HTMLElement>('h3')?.textContent ?? '';
    const html  = note.querySelector<HTMLElement>('.note-body')?.innerHTML ?? '';
    const bg    = getComputedStyle(note).background;
    ovLabel.textContent  = label;
    ovTitle.textContent  = title;
    ovBody.innerHTML     = html;
    ovPanel.style.background = bg;
    ovPanel.classList.add('open');
    ovBackdrop.classList.add('open');
  }
  function closeOverlay() {
    ovPanel.classList.remove('open');
    ovBackdrop.classList.remove('open');
  }
  document.getElementById('note-ov-close')?.addEventListener('click', closeOverlay);
  ovBackdrop.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeOverlay(); });

  // Note toggle: expand overlay on phone, inline accordion on tablet
  document.querySelectorAll<HTMLButtonElement>('.note-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      if (window.innerWidth <= 520) {
        const note = btn.closest<HTMLElement>('.note');
        if (note) openOverlay(note);
        return;
      }
      // tablet: inline toggle
      const note = btn.closest<HTMLElement>('.note');
      if (!note) return;
      const willOpen = !note.hasAttribute('data-open');
      note.toggleAttribute('data-open');
      btn.setAttribute('aria-expanded', String(willOpen));
    });
  });

  // ── Quick Look viewer ────────────────────────────────
  const qlViewer  = document.getElementById('ql-viewer')   as HTMLDialogElement;
  const qlBody    = document.getElementById('ql-body')!;
  const qlStrip   = document.getElementById('ql-strip')!;
  const qlWinTitle = document.getElementById('ql-win-title')!;
  const qlCounter = document.getElementById('ql-counter')!;
  const qlPrevBtn = document.getElementById('ql-prev')     as HTMLButtonElement;
  const qlNextBtn = document.getElementById('ql-next')     as HTMLButtonElement;

  interface SlideInfo { slug: string; folder: string; title: string; cover: string; el: HTMLElement; }
  let qlSlides: SlideInfo[] = [];
  let qlIdx = 0;

  function buildSlides(folder: string) {
    qlSlides = Array.from(document.querySelectorAll<HTMLElement>('.ql-slide'))
      .filter(el => el.dataset.folder === folder)
      .map(el => ({
        slug: el.dataset.slug!, folder: el.dataset.folder!,
        title: el.dataset.title!, cover: el.dataset.cover!, el,
      }));
  }

  function renderStrip() {
    qlStrip.innerHTML = '';
    qlSlides.forEach((s, i) => {
      const btn = document.createElement('button');
      btn.className = 'ql-strip-item' + (i === qlIdx ? ' ql-active' : '');
      btn.setAttribute('aria-label', s.title);
      const isData = s.folder === 'data';
      const thumb = s.cover
        ? `<img class="ql-strip-thumb" src="${s.cover}" alt="" />`
        : `<div class="ql-strip-ph" style="background:${isData ? '#dcfce7' : '#dbeafe'}">
             <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
               ${isData
                 ? '<rect x="3" y="12" width="3" height="8" rx="1" fill="#4ADE80"/><rect x="9" y="7" width="3" height="13" rx="1" fill="#22C55E"/><rect x="15" y="4" width="3" height="16" rx="1" fill="#16A34A"/>'
                 : '<circle cx="12" cy="12" r="8" stroke="#60A5FA" stroke-width="1.5" fill="none"/><ellipse cx="12" cy="12" rx="3.5" ry="8" stroke="#60A5FA" stroke-width="1.5" fill="none"/><line x1="4" y1="12" x2="20" y2="12" stroke="#60A5FA" stroke-width="1.5"/>'
               }
             </svg>
           </div>`;
      btn.innerHTML = thumb + `<span class="ql-strip-name">${s.title}</span>`;
      btn.addEventListener('click', () => goTo(i));
      qlStrip.appendChild(btn);
    });
  }

  function goTo(index: number) {
    qlIdx = Math.max(0, Math.min(qlSlides.length - 1, index));
    const s = qlSlides[qlIdx];
    qlBody.innerHTML = s.el.innerHTML;
    qlWinTitle.textContent = s.title;
    qlCounter.textContent  = `${qlIdx + 1} / ${qlSlides.length}`;
    qlPrevBtn.disabled = qlIdx === 0;
    qlNextBtn.disabled = qlIdx === qlSlides.length - 1;
    qlBody.scrollTop = 0;
    qlStrip.querySelectorAll('.ql-strip-item').forEach((item, i) => {
      item.classList.toggle('ql-active', i === qlIdx);
    });
    (qlStrip.querySelectorAll('.ql-strip-item')[qlIdx] as HTMLElement)
      ?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  function openViewer(slug: string, folder: string) {
    buildSlides(folder);
    const idx = qlSlides.findIndex(s => s.slug === slug);
    qlIdx = idx >= 0 ? idx : 0;
    renderStrip();
    goTo(qlIdx);
    try { qlViewer.showModal(); } catch { qlViewer.setAttribute('open', ''); }
  }
  function closeViewer() {
    try { qlViewer.close(); } catch { qlViewer.removeAttribute('open'); }
  }

  document.getElementById('ql-close')!.addEventListener('click', closeViewer);
  qlViewer.addEventListener('click', e => {
    const r = qlViewer.getBoundingClientRect();
    if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) closeViewer();
  });
  qlPrevBtn.addEventListener('click', () => goTo(qlIdx - 1));
  qlNextBtn.addEventListener('click', () => goTo(qlIdx + 1));

  // Keyboard arrows
  document.addEventListener('keydown', e => {
    if (!qlViewer.open) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(qlIdx + 1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   goTo(qlIdx - 1);
  });

  // Touch swipe
  let qlTouchX = 0;
  qlViewer.addEventListener('touchstart', e => { qlTouchX = e.touches[0].clientX; }, { passive: true });
  qlViewer.addEventListener('touchend',   e => {
    const dx = e.changedTouches[0].clientX - qlTouchX;
    if (Math.abs(dx) > 44) dx < 0 ? goTo(qlIdx + 1) : goTo(qlIdx - 1);
  });

  // Open project
  document.querySelectorAll<HTMLButtonElement>('[data-open-modal]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug   = btn.dataset.openModal!;
      const slideEl = document.getElementById(`ql-${slug}`);
      const folder  = slideEl?.dataset.folder ?? 'web';
      openViewer(slug, folder);
    });
  });
</script>

</body>
</html>
